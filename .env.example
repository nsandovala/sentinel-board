# ============================================================================
# Sentinel Board — Environment Variables
# ============================================================================
# Copia este archivo a .env.local y configura según tu setup.
# El board ahora usa Postgres. Para Render usa la External o Internal Database URL
# como `DATABASE_URL`. La IA sigue siendo opcional.
#
# Prioridad del router: Ollama → OpenRouter → Anthropic → Fallback heurístico
# ============================================================================

# ─── DATABASE (requerida) ───────────────────────────────────────────────────
# Render Postgres / Neon / cualquier PostgreSQL compatible.
# Ejemplo Render:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=
# Opcional: tamaño del pool de conexiones Node.js
PG_POOL_MAX=10
SENTINEL_API_TOKEN=

# ─── OLLAMA (primario) ──────────────────────────────────────────────────────
# Costo: $0 (local)
# Setup: https://ollama.ai → descargar → `ollama pull qwen3:8b`
# Si Ollama no está corriendo, se salta automáticamente al siguiente provider.
#
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ─── OPENROUTER (secundario) ────────────────────────────────────────────────
# Costo: Free tier disponible / ~$0.0001-0.001 por request según modelo
# Setup: https://openrouter.ai/keys → crear cuenta → copiar API key
# Si no hay key definida, se salta automáticamente.
#
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b:free

# ─── ANTHROPIC (terciario) ──────────────────────────────────────────────────
# Costo: ~$0.25/MTok input, $1.25/MTok output (Haiku 4.5)
#        Un análisis típico ≈ $0.001
# Setup: https://console.anthropic.com/ → API Keys → crear key
# Si no hay key definida, se salta automáticamente.
#
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── FALLBACK HEURÍSTICO ────────────────────────────────────────────────────
# Costo: $0 (100% local, sin red)
# Siempre disponible. Extrae estructura básica del texto usando regex.
# No requiere configuración — se activa automáticamente si todos los
# providers anteriores fallan o no están configurados.
